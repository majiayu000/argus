{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/majiayu000/argus/releases/manifest.schema.json",
  "title": "Argus release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "commit", "assets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "target", "kind", "size", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "target": { "enum": ["x86_64-unknown-linux-gnu", "aarch64-unknown-linux-gnu", "x86_64-apple-darwin", "aarch64-apple-darwin", "x86_64-pc-windows-msvc"] },
          "kind": { "enum": ["binary", "archive"] },
          "size": { "type": "integer", "minimum": 1, "maximum": 134217728 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
